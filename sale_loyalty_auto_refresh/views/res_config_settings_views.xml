<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='show_margins']" position="after">
                <setting
                    id="auto_refresh_coupons_settings"
                    title="Auto-refresh coupons"
                    help="When the sale order is updated, auto-refresh the promotion programs which are set to auto apply"
                >
                    <field name="auto_refresh_coupon" />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
